  "prorate_point" int [not null, default: '0', note: 'When project reached maximum projects, this column will be filled']
  "calculated_prorate_point" int [not null, default: '0', note: 'When project reached maximum projects, this column will be filled']
  "original_point" int [not null, default: '0', note: '1 task = 1 point']
  "created_at" timestamp
  "updated_at" timestamp

