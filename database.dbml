  "status" tinyint [not null]
  "created_at" timestamp
  "updated_at" timestamp
  "is_fully_paid" tinyint(1) [not null, default: '0', note: 'Define this project has been paid off or not']
  "cancel_reason" varchar(255)
  "is_have_interactive_element" tinyint(1) [not null, default: '0']
  "include_tax" tinyint(1) [not null, default: '0', note: 'This to show tax payment information in the quotation note only, price is not affected']
  "identifier_number" varchar(100)
  "deleted_at" timestamp
  "cancel_at" timestamp
  "published_at" timestamp
  "published_by" bigint [note: 'Published by']
  "cancel_by" bigint

