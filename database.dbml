  "collaboration" varchar(255)
  "note" text
  "interactive_note" text
  "led_area" double [not null, default: '0']
  "led_detail" longtext
  "interactive_detail" json [note: '[{"name":"interactive","led":[{"width":"1","height":"1"}],"total":"1 m<sup>2<\\\\/sup>","totalRaw":"1","textDetail":"1 x 1 m"}]']
  "interactive_area" varchar(10) [default: '0']
  "country_id" bigint
  "state_id" bigint
  "city_id" bigint
  "project_class_id" bigint [not null]
  "longitude" varchar(255)
  "latitude" varchar(255)
