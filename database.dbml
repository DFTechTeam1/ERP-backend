  "created_by" bigint [ref: > users.id, note: 'nullable']
  "created_at" timestamp
  "updated_at" timestamp
}

Table "entertainment_task_song_items" {
  "id" bigint [pk, not null, increment]
  "entertainment_task_id" bigint [not null, ref: > entertainment_tasks.id]
  "song_item_id" bigint [not null, ref: > project_song_items.id]
  "created_at" timestamp
  "updated_at" timestamp
}

Table "entertainment_task_deadlines_histories" {
  "id" bigint [pk, not null, increment]
  "task_id" bigint [ref: > entertainment_tasks.id]
  "deadline" timestamp [not null]
  "deadline_change_reason_id" bigint [note: '0 if user input custom reason']
  "custom_reason" varchar(255)
  "created_by" bigint [ref: > users.id, note: 'nullable']
  "created_at" timestamp
  "updated_at" timestamp
}

Table "entertainment_task_proof_of_works" {
  "id" bigint [pk, not null, increment]
  "task_id" bigint [ref: > entertainment_tasks.id]
  "nas_path" varchar(255)
  "file_path" json
  "created_by" bigint [ref: > users.id]
  "created_at" timestamp
  "updated_at" timestamp
}

Table "entertainment_task_pic_workstates" {
  "id" bigint [pk, not null, increment]
  "started_at" timestamp [not null]
  "first_finish_at" timestamp
  "complete_at" timestamp
  "task_id" bigint [not null, ref: > entertainment_tasks.id]
  "employee_id" bigint [not null, ref: > employees.id]
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    task_id [name: "entertainment_task_pic_workstates_task_id_foreign"]
    employee_id [name: "entertainment_task_pic_workstates_employee_id_foreign"]
  }
}

Table "entertainment_task_pic_approvalstates" {
  "id" bigint [pk, not null, increment]
  "pic_id" bigint [not null, ref: > employees.id]
  "task_id" bigint [not null, ref: > entertainment_tasks.id]
  "project_id" bigint [not null, ref: > projects.id]
  "work_state_id" bigint [not null, ref: > entertainment_task_pic_workstates.id]
  "started_at" timestamp [not null]
  "approved_at" timestamp
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    pic_id [name: "entertainment_task_pic_approvalstates_pic_id_foreign"]
    task_id [name: "entertainment_task_pic_approvalstates_task_id_foreign"]
    project_id [name: "entertainment_task_pic_approvalstates_project_id_foreign"]
    work_state_id [name: "entertainment_task_pic_approvalstates_work_state_id_foreign"]
  }
}

Table "entertainment_task_pic_holdstates" {
  "id" bigint [pk, not null, increment]
  "reason" varchar(255) [not null]
  "holded_at" timestamp
  "unholded_at" timestamp
  "task_id" bigint [not null, ref: > entertainment_tasks.id]
  "employee_id" bigint [not null, ref: > employees.id]
  "work_state_id" bigint [ref: > entertainment_task_pic_workstates.id]
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    task_id [name: "entertainment_task_pic_holdstates_task_id_foreign"]
    employee_id [name: "entertainment_task_pic_holdstates_employee_id_foreign"]
  }
}

Table "entertainment_task_pic_revisestates" {
  "id" bigint [pk, not null, increment]
  "task_id" bigint [not null, ref: > entertainment_tasks.id]
  "work_state_id" bigint [not null, ref: > entertainment_task_pic_workstates.id]
  "employee_id" bigint [not null, ref: > employees.id]
  "assign_at" timestamp
  "start_at" timestamp
  "finish_at" timestamp
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    task_id [name: "entertainment_task_pic_revisestates_task_id_foreign"]
    work_state_id [name: "entertainment_task_pic_revisestates_work_state_id_foreign"]
    employee_id [name: "entertainment_task_pic_revisestates_employee_id_foreign"]
  }
}

Table "entertainment_task_duration_histories" {
  "id" bigint [pk, not null, increment]
  "project_id" bigint [not null, ref: > projects.id]
  "task_id" bigint [not null, ref: > entertainment_tasks.id]
  "task_type" varchar(255) [not null, note: "song | production"]
  "pic_id" bigint [not null, ref: > employees.id, note: 'should be entertainment project manager']
  "employee_id" bigint [not null, ref: > employees.id]
  "task_full_duration" bigint [not null, default: '0']
  "task_holded_duration" bigint [not null, default: '0']
  "task_revised_duration" bigint [not null, default: '0']
  "task_actual_duration" bigint [not null, default: '0']
  "task_approval_duration" bigint [not null, default: '0']
  "total_task_holded" bigint [not null, default: '0']
  "total_task_revised" bigint [not null, default: '0']
  "created_at" timestamp
  "updated_at" timestamp

  Indexes {
    project_id [name: "entertainment_task_duration_histories_project_id_foreign"]
    task_id [name: "entertainment_task_duration_histories_task_id_foreign"]
    pic_id [name: "entertainment_task_duration_histories_pic_id_foreign"]
    employee_id [name: "entertainment_task_duration_histories_employee_id_foreign"]
  }
}

Table "entertainment_logs" {
  "id" bigint [pk, not null, increment]
  "description" varchar(255) [not null]
  "project_id" bigint [ref: > projects.id]
  "created_at" timestamp
  "updated_at" timestamp

  note: "Store all entertainment activity in each project"
}

