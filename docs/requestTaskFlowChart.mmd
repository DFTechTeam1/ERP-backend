    class PM_CREATE,PM_POOL,PM_ASSIGN_NEXT,PM_PRE_REVIEW,PM_REVIEW pmAction
    class MEMBER_BROWSE,CLAIM_ATTEMPT,MEMBER_CREATE,MEMBER_START,MEMBER_WORKING,UPLOAD,TEMPLATE_CHECK memberAction
    class RECORD_START,ATOMIC_LOCK,STATUS_COMPLETE,NEXT_BOARD,MEMBER_TASK_CREATED,TASK_ASSIGNED_POOL systemAction
    class CREATE_PATH,ROLE_CHECK,SLOT_CHECK_POOL,SLOT_CHECK_MEMBER,NAME_CHECK,BOARD_SET,POOL_BOARD_SET,MEMBER_BOARD_CHECK,AUTO_ACTIVE,LAST_BOARD,NEXT_BOARD_TYPE,STALE_CHECK,PM_CAN_VOID,PM_PRE_REVIEW decision
    class START,PROJECT_DONE,TASK_VOIDED,TASK_CANCELLED terminal
    class BLOCK_CREATE,BLOCK_POOL,BLOCK_MEMBER,BLOCK_NAME,BLOCK_LIMIT,RELEASE_CLAIM blocked
    class NOTIFY_PM_CLAIM,NOTIFY_PM_NEW,NOTIFY_PM_STALE notify