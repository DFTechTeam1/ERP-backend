APP_NAME="DF Data Center Staging"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://backend.dfactory.pro
STAGING_URL=https://backend.dfactory.pro

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=1

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
TELESCOPE_ENABLED=false
AUTH_GUARD=web

# ---------------------------------------------------------------------------
# Centralized auth — RS256 access tokens (Laravel is the sole issuer)
# Generate a keypair per environment with: php artisan jwt:keygen
# Both keys are base64-encoded PEM. Distribute ONLY JWT_PUBLIC_KEY to the
# non-Laravel services. NEVER commit the private key.
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=http://backend.localhost:8080
JWT_AUDIENCE=erp
JWT_KID=key-1
JWT_ACCESS_TTL=30
JWT_REFRESH_TTL=1
JWT_REFRESH_TTL_REMEMBER=30
JWT_REFRESH_GRACE_SECONDS=10
JWT_REFRESH_PRUNE_AFTER=7
JWT_REFRESH_COOKIE=df_refresh_token
# For a cross-site frontend (separate domain) use: SAME_SITE=none, SECURE=true,
# and a shared parent domain, e.g. JWT_REFRESH_COOKIE_DOMAIN=.dfactory.pro
JWT_REFRESH_COOKIE_DOMAIN=
JWT_REFRESH_COOKIE_PATH=/
JWT_REFRESH_COOKIE_SECURE=true
JWT_REFRESH_COOKIE_SAME_SITE=lax

# CORS for the centralized refresh-cookie flow. The frontend sends credentialed
# requests, so CORS must allow credentials and an explicit origin list (a
# wildcard origin is rejected by browsers once credentials are enabled).
# Comma-separated origins, e.g. https://staging.dfactory.pro,https://dfactory.pro
CORS_ALLOWED_ORIGINS=*
CORS_SUPPORTS_CREDENTIALS=false
